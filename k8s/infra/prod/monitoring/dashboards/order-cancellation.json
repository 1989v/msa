{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "ADR-0032 Phase 3 — Order Outbox / Cancellation 보상 흐름 가시성. Outbox lag, cancellation latency, TTL fallback 발화량.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Outbox PENDING row 수 — 정상 흐름이면 0~수 건. 누적 시 publisher 또는 broker 장애 의심.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "outbox_pending_count{application=~\"$application\"}",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Outbox PENDING rows by service",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Outbox publish 성공/실패 throughput. 실패율 ↑ 시 Kafka broker / topic 권한 / payload 직렬화 의심.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(outbox_publish_total{application=~\"$application\"}[1m])) by (application)",
          "legendFormat": "{{application}} success",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(outbox_publish_error_total{application=~\"$application\"}[1m])) by (application)",
          "legendFormat": "{{application}} error",
          "refId": "B"
        }
      ],
      "title": "Outbox publish rate (success vs error)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "order.order.cancelled 발행 시각 → inventory release 완료 시각 사이 latency (p50/p95/p99). SLA: p99 <= 5s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.5, sum(rate(order_cancellation_to_release_latency_seconds_bucket[5m])) by (le, reason))",
          "legendFormat": "p50 {{reason}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(order_cancellation_to_release_latency_seconds_bucket[5m])) by (le, reason))",
          "legendFormat": "p95 {{reason}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(order_cancellation_to_release_latency_seconds_bucket[5m])) by (le, reason))",
          "legendFormat": "p99 {{reason}}",
          "refId": "C"
        }
      ],
      "title": "Order cancellation → inventory release latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "TTL fallback (30분 expiry) 발화 누적. 정상 흐름이면 0. 발화 = order.order.cancelled 흐름 또는 Outbox 장애 의심.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(inventory_reservation_expired_total[1h])) by (warehouse_id)",
          "legendFormat": "warehouse {{warehouse_id}}",
          "refId": "A"
        }
      ],
      "title": "TTL fallback expiries (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Kafka consumer lag (inventory-service group). 누적 시 consumer 처리 지연 / 다운 의심.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(kafka_consumer_fetch_manager_records_lag{client_id=~\".*inventory-service.*\"}) by (topic, partition)",
          "legendFormat": "{{topic}}/{{partition}}",
          "refId": "A"
        }
      ],
      "title": "Kafka consumer lag — inventory-service",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["adr-0032", "outbox", "cancellation", "saga"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(outbox_pending_count, application)",
        "hide": 0,
        "includeAll": true,
        "label": "Application",
        "multi": true,
        "name": "application",
        "options": [],
        "query": "label_values(outbox_pending_count, application)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Order Cancellation / Outbox (ADR-0032)",
  "uid": "adr-0032-order-cancellation",
  "version": 1
}
