{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "ADR-0029 PR-9 — Idempotent Consumer Helper 메트릭 (processed/skip/race/missingId). Skip 비율 급변, eventId 누락, race 빈도, processed_event 테이블 row 수 추이를 한 화면에서 확인.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Idempotent consumer 처리 throughput (per 1m). result ∈ {processed, skipped, race, error}. consumer_group / result 별 stacked 라인.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (consumer_group, result) (rate(kgd_idempotent_processed_total{consumer_group=~\"$consumer_group\"}[1m]))",
          "legendFormat": "{{consumer_group}} / {{result}}",
          "refId": "A"
        }
      ],
      "title": "Idempotent processed throughput by result",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Skip 비율 = skipped / (processed + skipped + race). 정상 운영에서는 0~수% 수준. 급증은 publisher 측 중복 발행 / consumer rebalance / 재처리 의심.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.3 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (consumer_group) (rate(kgd_idempotent_processed_total{result=\"skipped\", consumer_group=~\"$consumer_group\"}[5m]))\n/\nclamp_min(\n  sum by (consumer_group) (rate(kgd_idempotent_processed_total{consumer_group=~\"$consumer_group\"}[5m])),\n  0.001\n)",
          "legendFormat": "{{consumer_group}}",
          "refId": "A"
        }
      ],
      "title": "Skip ratio (skipped / total) — 5m",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "eventId 누락 → graceful degrade (UUID 생성) 빈도. 정상 운영에서는 0 이어야 함. 발화 시 publisher 측 헤더/필드 누락 점검.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (consumer_group) (increase(kgd_idempotent_event_missing_id_total{consumer_group=~\"$consumer_group\"}[1h]))",
          "legendFormat": "{{consumer_group}}",
          "refId": "A"
        }
      ],
      "title": "eventId missing (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "RACE outcome — 멀티 인스턴스 동시 INSERT 충돌. 0~수% 정상. 급증은 DB lock 경합 / 재시도 폭증 의심.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (consumer_group) (rate(kgd_idempotent_processed_total{result=\"race\", consumer_group=~\"$consumer_group\"}[5m]))",
          "legendFormat": "{{consumer_group}}",
          "refId": "A"
        }
      ],
      "title": "RACE rate — 5m",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Idempotent error outcome — 헬퍼 내부 예외 (DB 장애 / TX 실패 등). 0 이 정상.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (consumer_group) (increase(kgd_idempotent_processed_total{result=\"error\", consumer_group=~\"$consumer_group\"}[1h]))",
          "legendFormat": "{{consumer_group}}",
          "refId": "A"
        }
      ],
      "title": "Idempotent error count (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Cleanup 스케줄러 실행 — Spring @Scheduled 기반. cron=0 30 3 * * * Asia/Seoul (서비스별 분산). 24h 동안 increase 가 0 이면 cleanup 미실행. (Spring observation 메트릭 spring_scheduled_tasks_seconds_count 사용. ServiceMonitor 가 application 라벨을 부여하므로 scheduler 클래스명으로 필터.)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application) (increase(spring_scheduled_tasks_seconds_count{application=~\"$application\", classname=~\".*IdempotentEventCleanupScheduler.*\"}[1d]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Cleanup executions (last 24h)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["adr-0029", "idempotent", "kafka", "consumer"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kgd_idempotent_processed_total, consumer_group)",
        "hide": 0,
        "includeAll": true,
        "label": "Consumer group",
        "multi": true,
        "name": "consumer_group",
        "options": [],
        "query": "label_values(kgd_idempotent_processed_total, consumer_group)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kgd_idempotent_processed_total, application)",
        "hide": 0,
        "includeAll": true,
        "label": "Application",
        "multi": true,
        "name": "application",
        "options": [],
        "query": "label_values(kgd_idempotent_processed_total, application)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Idempotent Consumer (ADR-0029)",
  "uid": "adr-0029-idempotent-consumer",
  "version": 1
}
