[mysqld]
server-id                   = 4
relay-log                   = relay-bin
read-only                   = ON
super-read-only             = ON

gtid-mode                   = ON
enforce-gtid-consistency    = ON

max-connections             = 300
innodb-buffer-pool-size     = 256M

character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
skip-character-set-client-handshake

[client]
default-character-set       = utf8mb4

[mysql]
default-character-set       = utf8mb4
