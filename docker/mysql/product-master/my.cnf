[mysqld]
# Replication — Master
server-id                   = 1
log-bin                     = mysql-bin
binlog-format               = ROW
binlog-do-db                = product_db
expire-logs-days            = 7

# GTID
gtid-mode                   = ON
enforce-gtid-consistency    = ON

# Performance
max-connections             = 300
innodb-buffer-pool-size     = 256M
innodb-log-file-size        = 64M
innodb-flush-log-at-trx-commit = 1
sync-binlog                 = 1

# Character
character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
