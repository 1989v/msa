# Copy this file to .env and fill in actual values

COMPOSE_PROJECT_NAME=commerce-platform

MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_USER=commerce
MYSQL_PASSWORD=your_password
REPLICATION_PASSWORD=your_replication_password

REDIS_PASSWORD=your_redis_password

JWT_SECRET=your-jwt-secret-key-must-be-at-least-32-characters
AES_KEY=your-aes-key-exactly-32-bytes!!!

MYSQL_VERSION=8.0
REDIS_VERSION=7.2
ELASTICSEARCH_VERSION=8.17.0

SPRING_PROFILES_ACTIVE=docker

# search-batch 색인 소스 (api | db)
REINDEX_SOURCE=api

# OAuth2
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ClickHouse
CLICKHOUSE_USER=analytics
CLICKHOUSE_PASSWORD=analytics
CLICKHOUSE_DB=analytics
CLICKHOUSE_VERSION=24.3
